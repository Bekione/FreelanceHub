generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// BETTER-AUTH TABLES
// Required by better-auth. Do not rename these models or their core fields.
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Onboarding Data
  onboardingCompleted Boolean @default(false)
  role                String?
  companySize         String?
  themePreference     String?
  plan                String    @default("free")

  // Stripe Billing
  stripeCustomerId     String?
  stripeSubscriptionId String?
  subscriptionStatus   String?   // active | past_due | canceled | unpaid
  currentPeriodEnd     DateTime?

  // Rate Limiting
  lastEmailSentAt      DateTime?

  // App relations
  profile       Profile?
  projects      Project[]
  clients       Client[]
  invoices      Invoice[]
  timeEntries   TimeEntry[]

  // Auth relations (managed by better-auth)
  sessions      Session[]
  accounts      Account[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                   String    @id @default(cuid())
  userId               String
  accountId            String
  providerId           String
  accessToken          String?   @db.Text
  refreshToken         String?   @db.Text
  accessTokenExpiresAt DateTime?
  refreshTokenExpiresAt DateTime?
  scope                String?
  idToken              String?   @db.Text
  password             String?   @db.Text
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
}

model RateLimit {
  id          String   @id
  key         String
  count       Int
  lastRequest DateTime
}

// ─────────────────────────────────────────────────────────────────────────────
// APP MODELS
// ─────────────────────────────────────────────────────────────────────────────

// Extended freelancer profile (separate from auth User)
model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  bio         String?
  website     String?
  location    String?
  phone       String?
  hourlyRate  Float?
  currency    String   @default("USD")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Branding (Pro-only features — stored for all, only rendered for Pro)
  brandLogoUrl     String?
  brandColor       String?  @default("#f59e0b")
  invoicePrefix    String?  @default("INV-")

  // User Preferences
  theme              String  @default("system")
  dateFormat         String  @default("MM/DD/YYYY")
  autoCreateInvoice  Boolean @default(false)
  defaultCurrency    String  @default("USD")
  timezone           String  @default("UTC")
  emailNotifications Boolean @default(true)

  // Billing & Payment Settings
  paymentDetails     String? @db.Text

  // Portal Limits
  freePortalUsed     Boolean @default(false)

  // i18n preference — stored as a BCP 47 locale string
  language           String  @default("en")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Waitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}


model Client {
  id        String    @id @default(cuid())
  name      String
  email     String?
  company   String?
  phone     String?
  notes     String?
  imageUrl  String?   // Client profile photo (Cloudinary URL)
  userId    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft-delete: null = active, set = trashed

  // Client Portal capabilities
  hasPortal   Boolean @default(false)
  portalToken String? @unique

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects  Project[]
  invoices  Invoice[]
}

model Project {
  id          String        @id @default(cuid())
  title       String
  description String?
  status      ProjectStatus @default(PENDING)
  deadline    DateTime?
  budget      Float?
  // Bonus on top of project price (client may pay extra)
  bonus       Float?        @default(0)
  // Platform tag — where the job came from
  platform    String?       // e.g. "upwork", "fiverr", "local", "remotive"
  category    String?       @default("other") // "development", "design", "copywriting", "video", "other"
  userId      String
  clientId    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?     // soft-delete: null = active, set = trashed

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  client      Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  invoices    Invoice[]
  timeEntries TimeEntry[]
  attachments Attachment[]
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  amount        Float
  // Bonus amount added to this invoice (if any)
  bonus         Float?        @default(0)
  status        InvoiceStatus @default(DRAFT)
  issueDate     DateTime      @default(now())
  dueDate       DateTime
  notes         String?
  userId        String
  clientId      String?
  projectId     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?     // soft-delete: null = active, set = trashed

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  client        Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  project       Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  items         InvoiceItem[]
}

model InvoiceItem {
  id          String   @id @default(cuid())
  description String
  quantity    Float
  unitPrice   Float
  invoiceId   String
  createdAt   DateTime @default(now())

  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model TimeEntry {
  id          String    @id @default(cuid())
  description String?
  startTime   DateTime
  endTime     DateTime?
  // Duration in seconds (cached for quick queries)
  duration    Int?
  userId      String
  projectId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model Attachment {
  id        String   @id @default(cuid())
  name      String
  url       String
  size      Int
  mimeType  String?
  category  String?  @default("other") // "code", "design", "document", "media", "other"
  projectId String
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── System metadata — used for uptime tracking ───────────────────────────────
model SystemMeta {
  key   String @id
  value String
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum ProjectStatus {
  PENDING
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
  CANCELLED
}
